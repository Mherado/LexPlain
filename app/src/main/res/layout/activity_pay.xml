<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Премиум Доступ"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Разблокируйте ИИ-конспекты договоров"
        android:textSize="16sp"
        android:layout_marginBottom="40dp"
        android:gravity="center"/>
    <Button
        android:id="@+id/btnBuyTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тест-драйв (1 минута) — 0$"
        android:layout_marginBottom="16dp"/>
    <Button
        android:id="@+id/btnBuyMonth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1 Месяц VIP — 4.99$"
        android:layout_marginBottom="16dp"/>
    <Button
        android:id="@+id/btnBuyYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1 Год VIP — 29.99$"/>
</LinearLayout>